# This file is committed because it only points direnv at the local secret
# environment file. Do not put secret values here.
export OTARU_SECRETS_DIR="${OTARU_SECRETS_DIR:-$HOME/dotfiles/secrets/otaru}"
export OTARU_TF_CONFIG_FILE="${OTARU_TF_CONFIG_FILE:-$OTARU_SECRETS_DIR/tfconfig}"
source_env "$OTARU_SECRETS_DIR/envrc"
